# ============================================================
# TechNova — copia este archivo a `.env` y completa los valores
# ============================================================

# --- Database (Neon Postgres) ---
# Dashboard → tu proyecto → Connection Details → Pooled connection
DATABASE_URL=postgres://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require

# --- Email transaccional (Resend) ---
# https://resend.com/api-keys → "Create API Key"
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Dirección "From" para todos los correos transaccionales.
# Requiere dominio verificado en https://resend.com/domains
# Formato: "Nombre Visible <noreply@tudominio.com>"
# Si no se define, cae al dominio testing de Resend (solo envía al owner de la cuenta).
RESEND_FROM_EMAIL="TechNova <noreply@technova.mx>"

# --- Pagos (Stripe) — pendiente activación, ver docs/STRIPE_SETUP.md ---
# https://dashboard.stripe.com/apikeys
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_BASE_URL=https://technova.mx
