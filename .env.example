# ============================================================
# TechNova — copia este archivo a `.env` y completa los valores
# ============================================================

# --- Database (Neon Postgres) ---
# Dashboard → tu proyecto → Connection Details → Pooled connection
DATABASE_URL=postgres://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require

# --- Email transaccional (Resend) ---
# https://resend.com/api-keys → "Create API Key"
RESEND_API_KEY=PEGA_TU_API_KEY_AQUI

# Dirección "From" para todos los correos transaccionales.
# Requiere dominio verificado en https://resend.com/domains
# Formato: "Nombre Visible <noreply@tudominio.com>"
# Si no se define, cae al dominio testing de Resend (solo envía al owner de la cuenta).
RESEND_FROM_EMAIL="TechNova <noreply@technova.mx>"

# --- Pagos (Stripe) ---
# Test keys: https://dashboard.stripe.com/test/apikeys
# Live keys: https://dashboard.stripe.com/apikeys (requiere cuenta activada por Stripe)
# El SDK npm `stripe` está pinneado a apiVersion 2026-03-25.dahlia en src/lib/stripe.ts
STRIPE_SECRET_KEY=PEGA_TU_STRIPE_SECRET_KEY_AQUI
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=PEGA_TU_STRIPE_PUBLISHABLE_KEY_AQUI

# Webhook signing secret. Obtenido al crear el endpoint en
# https://dashboard.stripe.com/test/webhooks → tu endpoint → "Signing secret".
# El endpoint debe apuntar a https://tudominio.com/api/checkout/webhook
STRIPE_WEBHOOK_SECRET=PEGA_TU_WEBHOOK_SECRET_AQUI

# Base URL absoluta usada por Stripe Checkout para construir success_url y cancel_url.
# Debe coincidir con el dominio donde está desplegada la app.
NEXT_PUBLIC_BASE_URL=https://tech-nova.mx

# --- Dashboards internos (/admin/* y /internal/*) ---
# Token que protege los dashboards de status y arquitectura (src/middleware.ts).
# Acceso desde browser: https://tech-nova.mx/admin/project-status?token=TU_TOKEN
# (setea cookie httpOnly por 8h y limpia la URL). curl: header `x-admin-token`.
# Sin esta var, /admin/* y /internal/* responden 503 (cerrado por defecto).
ADMIN_DASHBOARD_TOKEN=GENERA_UN_TOKEN_LARGO_Y_ALEATORIO

# --- Rate limiting (Upstash Redis serverless) ---
# https://console.upstash.com → Create Database → Redis → REST API tab
# Sin estas vars, src/middleware.ts degrada gracefully (deja pasar todas las requests).
UPSTASH_REDIS_REST_URL=PEGA_TU_URL_AQUI
UPSTASH_REDIS_REST_TOKEN=PEGA_TU_TOKEN_AQUI
